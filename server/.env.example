# Copy this file to `.env` and fill in real values.

# HTTP
PORT=5000

# CORS — comma-separated allowlist of origins permitted to call the API.
# '*' allows any origin (dev convenience). In production list the exact
# frontend origins, e.g.:
#   CORS_ORIGIN=http://localhost:5173,https://keep-territories.ru,https://www.keep-territories.ru
CORS_ORIGIN=*

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vkr
DB_USER=postgres
DB_PASSWORD=changeme

# JWT
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d
