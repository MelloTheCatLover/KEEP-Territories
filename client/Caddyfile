# Caddy serves the built SPA from /srv. The SPA talks directly to the API
# host (api.keep-territories.ru) via VITE_API_BASE_URL, so no /api proxy here.
# DOMAIN is taken from compose env. For local/no-domain use DOMAIN=":80".

{$DOMAIN} {
	encode zstd gzip

	# Static SPA with client-side routing fallback
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	# Security headers — Caddy adds HSTS automatically when serving via LE
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}
}
