# Copy to .env on the VPS:  cp .env.prod.example .env
# Then edit values and: docker compose --env-file .env up -d --build

# --- Domains ------------------------------------------------------------
# Frontend host Caddy serves the SPA on (Caddy auto-issues Let's Encrypt).
# Multiple hosts comma-separated work in Caddy (no spaces around comma).
DOMAIN=keep-territories.ru,www.keep-territories.ru
# The backend is deployed separately (its own host/app) at api.keep-territories.ru.
# The frontend no longer proxies /api — the SPA calls the API host directly.

# --- Frontend → API URL (baked into the SPA bundle at build time) -------
VITE_API_BASE_URL=https://api.keep-territories.ru/api

# --- CORS ---------------------------------------------------------------
# Comma-separated allowlist of frontend origins permitted to call the API.
CORS_ORIGIN=https://keep-territories.ru,https://www.keep-territories.ru

# --- PostgreSQL ---------------------------------------------------------
DB_NAME=vkr
DB_USER=vkr
# Generate: openssl rand -hex 24
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# --- JWT ----------------------------------------------------------------
# Generate: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRES_IN=7d

# --- Misc ---------------------------------------------------------------
TZ=Europe/Berlin
BACKUP_RETENTION_DAYS=14
