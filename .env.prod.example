# Copy to .env on the VPS:  cp .env.prod.example .env
# Then edit values and: docker compose --env-file .env up -d --build

# --- Public hostname Caddy serves on -----------------------------------
# IP-only / no domain (default — HTTP on port 80, accessible at http://<vps-ip>):
DOMAIN=:80
# Later, when you add a domain, switch to (Caddy will auto-issue Let's Encrypt):
#   DOMAIN=keep-territories.online, www.keep-territories.online
# Multiple hosts comma-separated work in Caddy (no spaces around comma).

# --- CORS ---------------------------------------------------------------
# With same-origin SPA + Caddy this is irrelevant; keep '*' or list domains.
CORS_ORIGIN=*

# --- PostgreSQL ---------------------------------------------------------
DB_NAME=vkr
DB_USER=vkr
# Generate: openssl rand -hex 24
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# --- JWT ----------------------------------------------------------------
# Generate: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRES_IN=7d

# --- Misc ---------------------------------------------------------------
TZ=Europe/Berlin
BACKUP_RETENTION_DAYS=14
